<?xml version="1.0" encoding="UTF-8"?>
<resources>
    <!-- Base DayNight Theme -->
    <style name="AppTheme.DayNight" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>
        
        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/md_theme_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_onTertiaryContainer</item>
        
        <!-- Error color -->
        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>
        <item name="colorErrorContainer">@color/md_theme_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_onErrorContainer</item>
        
        <!-- Surface colors -->
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorOnBackground">@color/md_theme_onBackground</item>
        
        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_outlineVariant</item>
        
        <!-- Status and navigation bars -->
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:navigationBarColor">@color/navigation_bar_color</item>
        <item name="android:windowLightStatusBar">@bool/is_light_theme</item>
        <item name="android:windowLightNavigationBar">@bool/is_light_theme</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorTertiary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        
        <!-- Control colors -->
        <item name="colorControlActivated">?attr/colorPrimary</item>
        <item name="colorControlHighlight">?attr/colorOnSurface</item>
        <item name="colorControlNormal">?attr/colorOnSurfaceVariant</item>
        
        <!-- Additional customizations -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowBackground">@color/md_theme_onBackground</item>
        <item name="android:colorAccent">?attr/colorPrimary</item>
    </style>

    <!-- Text styles -->
    <style name="TextHeader" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>
    <style name="TextHeader.DayNight" parent="TextHeader">
    </style>

    <style name="TextTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextTitle.DayNight" parent="TextTitle">
    </style>

    <style name="TextBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextBody.DayNight" parent="TextBody">
    </style>

    <style name="TextCaption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextCaption.DayNight" parent="TextCaption">
    </style>

    <!-- Button styles -->
    <style name="ButtonPrimary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="ButtonPrimary.DayNight" parent="ButtonPrimary">
    </style>

    <style name="ButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
    </style>
    <style name="ButtonSecondary.DayNight" parent="ButtonSecondary">
    </style>

    <style name="TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">20dp</item>
    </style>
    <style name="TextButton.DayNight" parent="TextButton">
    </style>

    <!-- Card styles -->
    <style name="CardViewStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="CardViewStyle.DayNight" parent="CardViewStyle">
    </style>
    
    <style name="CardViewStyle_total" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="CardViewStyle_total.DayNight" parent="CardViewStyle_total">
    </style>

    <!-- TextInputLayout styles -->
    <style name="Widget.Material3.TextInputLayout.OutlinedBox.Dense" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">?attr/colorSurface</item>
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusBottomEnd">4dp</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
        <item name="helperTextTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="errorTextColor">?attr/colorError</item>
        <item name="startIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="endIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="errorIconTint">?attr/colorError</item>
        <item name="suffixTextColor">?attr/colorOnSurfaceVariant</item>
    </style>
    <style name="Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
    </style>
    
    <style name="Widget.Material3.TextInputLayout.FilledBox.Dense" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
        <item name="helperTextTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="suffixTextColor">?attr/colorOnSurfaceVariant</item>
    </style>
    <style name="Widget.Material3.TextInputLayout.FilledBox.Dense.DayNight" parent="Widget.Material3.TextInputLayout.FilledBox.Dense">
    </style>

    <!-- Exposed Dropdown Menu Style -->
    <style name="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">?attr/colorSurface</item>
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusBottomEnd">4dp</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
        <item name="helperTextTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="errorTextColor">?attr/colorError</item>
        <item name="endIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="errorIconTint">?attr/colorError</item>
    </style>
    <style name="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu.DayNight" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
    </style>

    <!-- Icon button styles -->
    <style name="Widget.Material3.Button.IconButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    <style name="Widget.Material3.Button.IconButton.DayNight" parent="Widget.Material3.Button.IconButton">
    </style>

    <!-- Floating Action Button -->
    <style name="Widget.Material3.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="tint">?attr/colorOnPrimary</item>
        <item name="android:tint">?attr/colorOnPrimary</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
        <item name="elevation">6dp</item>
        <item name="pressedTranslationZ">8dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Material3.FloatingActionButton</item>
    </style>
    <style name="Widget.Material3.FloatingActionButton.DayNight" parent="Widget.Material3.FloatingActionButton">
    </style>

    <!-- Divider style -->
    <style name="DividerStyle">
        <item name="android:background">?attr/colorOutlineVariant</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_width">match_parent</item>
    </style>
    <style name="DividerStyle.DayNight" parent="DividerStyle">
    </style>

    <!-- Bottom Sheet Style -->
    <style name="Widget.Material3.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Material3.BottomSheet</item>
    </style>
    <style name="Widget.Material3.BottomSheet.DayNight" parent="Widget.Material3.BottomSheet">
    </style>

    <!-- Tab Layout -->
    <style name="Widget.Material3.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabTextAppearance">@style/CustomTabText</item>
        <item name="tabIndicatorColor">?attr/colorPrimary</item>
        <item name="tabSelectedTextColor">?attr/colorPrimary</item>
        <item name="tabTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="tabBackground">?attr/colorSurface</item>
        <item name="tabRippleColor">?attr/colorControlHighlight</item>
        <item name="tabIndicatorHeight">3dp</item>
    </style>
    <style name="Widget.Material3.TabLayout.DayNight" parent="Widget.Material3.TabLayout">
    </style>

    <style name="CustomTabText" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    <style name="CustomTabText.DayNight" parent="CustomTabText">
    </style>

    <!-- Toolbar -->
    <style name="Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:theme">@style/ThemeOverlay.Material3.Toolbar</item>
        <item name="popupTheme">@style/ThemeOverlay.Material3.Toolbar</item>
        <item name="android:elevation">4dp</item>
    </style>
    <style name="Toolbar.DayNight" parent="Toolbar">
    </style>

    <!-- Search View -->
    <style name="SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="queryBackground">@android:color/transparent</item>
        <item name="submitBackground">@android:color/transparent</item>
    </style>
    <style name="SearchView.DayNight" parent="SearchView">
    </style>

    <!-- Bottom Navigation -->
    <style name="BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">?attr/colorSurface</item>
        <item name="itemIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="itemTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:elevation">8dp</item>
    </style>
    <style name="BottomNavigation.DayNight" parent="BottomNavigation">
    </style>

    <!-- Bottom App Bar -->
    <style name="Widget.Material3.BottomAppBar.Custom" parent="Widget.MaterialComponents.BottomAppBar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="fabAlignmentMode">end</item>
        <item name="fabAnimationMode">slide</item>
        <item name="hideOnScroll">false</item>
    </style>
    <style name="Widget.Material3.BottomAppBar.Custom.DayNight" parent="Widget.Material3.BottomAppBar.Custom"></style>

    <!-- Switch style -->
    <style name="Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">?attr/colorPrimary</item>
        <item name="trackTint">?attr/colorSurfaceVariant</item>
    </style>
    <style name="Switch.DayNight" parent="Switch">
    </style>

    <!-- Progress bar -->
    <style name="ProgressBar" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">?attr/colorSurfaceVariant</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>
    <style name="ProgressBar.DayNight" parent="ProgressBar">
    </style>

    <!-- Chip Style -->
    <style name="Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="chipStrokeColor">?attr/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
    <style name="Chip.DayNight" parent="Chip">
    </style>

    <!-- Notification Card Style -->
    <style name="NotificationCard" parent="CardViewStyle">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="NotificationCard.DayNight" parent="NotificationCard">
    </style>

    <!-- Contact Avatar Style -->
    <style name="ContactAvatar">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/circle_background</item>
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="ContactAvatar.DayNight" parent="ContactAvatar">
    </style>

    <!-- Shape Appearance Overlays -->
    <style name="ShapeAppearanceOverlay.Material3.FloatingActionButton" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.Material3.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Theme Overlays -->
    <style name="ThemeOverlay.Material3.Toolbar" parent="ThemeOverlay.Material3.Dark" />
    <style name="ThemeOverlay.Material3.Toolbar.DayNight" parent="ThemeOverlay.Material3.ActionBar" />
    
    <!-- Table Styles -->
    <style name="TableHeaderStyle" parent="">
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_margin">0.5dp</item>
        <item name="android:backgroundTintMode">src_in</item>
    </style>
    <style name="TableHeaderStyle.DayNight" parent="TableHeaderStyle">
    </style>

    <style name="TableCellStyle" parent="">
        <item name="android:background">?attr/colorSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_margin">0.5dp</item>
    </style>
    <style name="TableCellStyle.DayNight" parent="TableCellStyle">
    </style>

    <style name="TableEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:inputType">numberDecimal</item>
        <item name="android:layout_margin">0.5dp</item>
    </style>
    <style name="TableEditTextStyle.DayNight" parent="TableEditTextStyle">
    </style>

</resources>