<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/vscroll1"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:theme="@style/AppTheme.DayNight"
	android:fillViewport="true">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="24dp"
		android:orientation="vertical">
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			style="@style/CardViewStyle.DayNight"
			app:cardCornerRadius="20dp"
			app:cardElevation="2dp">
			<LinearLayout
				android:id="@+id/linear11"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="24dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/imageview1"
					android:layout_width="80dp"
					android:layout_height="80dp"
					android:layout_marginBottom="16dp"
					android:src="@drawable/bug_fixing"
					android:scaleType="fitCenter"
					android:contentDescription="@string/bug_icon_description" />
				<TextView
					android:id="@+id/textview2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="@string/app_crashed_title"
					android:textSize="12sp"
					android:textColor="#000000"
					style="@style/TextHeader.DayNight" />
				<TextView
					android:id="@+id/textview3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:text="@string/crash_description"
					android:textSize="12sp"
					android:textColor="#000000"
					style="@style/TextBody.DayNight"
					android:lineSpacingExtra="4dp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview5"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			style="@style/CardViewStyle"
			app:cardCornerRadius="16dp">
			<LinearLayout
				android:id="@+id/linear12"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="20dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview6"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="12dp"
					android:text="@string/describe_issue_title"
					android:textSize="12sp"
					android:textColor="#000000"
					style="@style/TextTitle.DayNight" />
				<com.google.android.material.textfield.TextInputLayout
					android:id="@+id/textinputlayout2"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
					app:boxCornerRadiusTopStart="12dp"
					app:boxCornerRadiusTopEnd="12dp"
					app:boxCornerRadiusBottomStart="12dp"
					app:boxCornerRadiusBottomEnd="12dp"
					app:helperText="@string/feedback_helper_text">
					<com.google.android.material.textfield.TextInputEditText
						android:id="@+id/edittext1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:textSize="14sp"
						android:textColor="#000000"
						android:textColorHint="#607D8B"
						android:gravity="top|start"
						android:inputType="textMultiLine|textCapSentences"
						android:minLines="4"
						android:maxLines="6"
						android:scrollbars="vertical" />
				</com.google.android.material.textfield.TextInputLayout>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview6"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			style="@style/CardViewStyle"
			app:cardCornerRadius="16dp">
			<LinearLayout
				android:id="@+id/linear13"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/linear5"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="20dp"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:background="?attr/selectableItemBackground"
					android:focusable="true">
					<TextView
						android:id="@+id/textview4"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:text="@string/view_error_log"
						android:textSize="12sp"
						android:layout_weight="1"
						android:textColor="?attr/colorPrimary"
						style="@style/TextTitle"
						android:drawableStart="@drawable/ic_code_24dp"
						android:drawablePadding="12dp" />
					<ImageView
						android:id="@+id/imageview2"
						android:layout_width="24dp"
						android:layout_height="24dp"
						android:src="@drawable/twotone_keyboard_arrow_down_black_48dp"
						android:scaleType="center"
						android:contentDescription="@string/expand_collapse_description"
						app:tint="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
				<View
					android:id="@+id/view14"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					style="@style/DividerStyle"
					android:layout_marginHorizontal="20dp" />
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="20dp"
					android:orientation="vertical"
					android:visibility="gone">
					<TextView
						android:id="@+id/textview1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="16dp"
						android:text="@string/error_log_placeholder"
						android:textSize="12sp"
						android:background="?attr/colorSurfaceVariant"
						android:textColor="?attr/colorOnSurfaceVariant"
						android:fontFamily="monospace"
						android:scrollbars="vertical"
						android:maxLines="10"
						android:scrollHorizontally="true"
						android:ellipsize="end" />
					<com.google.android.material.button.MaterialButton
						android:id="@+id/button_copy_log"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:text="@string/copy_log_button"
						android:textSize="12sp"
						android:textColor="#000000"
						android:layout_gravity="end"
						style="@style/TextButton"
						app:icon="@drawable/ic_copy_24dp"
						app:iconGravity="start" />
				</LinearLayout>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<LinearLayout
			android:id="@+id/linear8"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical">
			<com.google.android.material.button.MaterialButton
				android:id="@+id/button2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:text="@string/send_report_button"
				android:textSize="12sp"
				android:textColor="#000000"
				style="@style/ButtonPrimary"
				app:icon="@drawable/ic_send_24dp"
				app:iconGravity="start"
				android:paddingVertical="16dp" />
			<com.google.android.material.button.MaterialButton
				android:id="@+id/button1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/restart_app_button"
				android:textSize="12sp"
				android:textColor="#000000"
				style="@style/ButtonSecondary"
				app:icon="@drawable/ic_refresh_24dp"
				app:iconGravity="start"
				android:paddingVertical="16dp" />
		</LinearLayout>
		<TextView
			android:id="@+id/textview_support"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:padding="8dp"
			android:text="@string/contact_support_text"
			android:textSize="12sp"
			android:layout_gravity="center_horizontal|center_vertical"
			android:background="?attr/selectableItemBackground"
			android:textColor="?attr/colorPrimary"
			style="@style/TextCaption"
			android:focusable="true" />
	</LinearLayout>
</ScrollView>
