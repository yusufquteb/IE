<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackground"
    android:layoutDirection="rtl">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="مشاريعي الهندسية" android:textSize="16sp"
            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_manage_projects"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إدارة المشاريع" />
    </LinearLayout>
    <TextView android:id="@+id/tv_no_projects"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="لا توجد مشاريع\nاضغط 'إدارة المشاريع' لإنشاء مشروع جديد"
        android:textSize="14sp" android:gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:padding="32dp" android:visibility="gone" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_projects_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />
</LinearLayout>
