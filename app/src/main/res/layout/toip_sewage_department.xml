<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/_coordinator"
	android:layout_width="match_parent"
	android:layout_height="match_parent">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/_app_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/AppTheme.AppBarOverlay">
		<androidx.appcompat.widget.Toolbar
			android:id="@+id/_toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="?attr/colorPrimary"
			app:popupTheme="@style/AppTheme.PopupOverlay" />
	</com.google.android.material.appbar.AppBarLayout>
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<com.google.android.gms.ads.AdView
			android:id="@+id/adview1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:adSize="SMART_BANNER"
			app:adUnitId="ca-app-pub-8740221854029861/1241530910" />
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="8dp"
			android:background="#E0F2F1">
			<LinearLayout
				android:id="@+id/linear1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FFFFFF"
					android:gravity="center_horizontal|center_vertical"
					android:text="أقسام المكتب الفني لأعمال البنية التحتية\n-------------------------------------------"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000"
					android:layout_gravity="center_horizontal" />
				<Button
					android:id="@+id/button1"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب الطول الفعلي لمواسير فرعة شامل الهالك والتداخل وخلافه"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button2"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب عمق وميل فرعة ومقارنته بالميل المكتوب علي اللوحة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button14"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب منسوب دخول فرعة علي مطبق مصب أي منسوب نهاية الفرعة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button15"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب منسوب خروج فرعة من مطبق بداية الفرعة أي منسوب بداية الفرعة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button16"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="دراسة سرعة السريان بمواسير الأنحدار"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button17"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="عمل Check علي ضغط وقطر خط الطرد"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button9"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب كمية الخرسانة بالمطبق"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button10"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="دراسات أسعار خطوط الأنحدار\n( بلاستيك UPVC )"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button11"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="دراسات أسعار خطوط الطرد\n( بولي إيثلين أملس HDPE )"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button12"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="دراسة سعر أي بند باستخدام سعر القائمة الأسترشادية للهيئة القومية لمياه الشرب والصرف الصحى"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button13"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="دراسة أسعار بنود التجفيف المختلفة ( سواء للخطوط أو المنشآت ) بتطبيق معادلة التجفيف بقائمة الهيئة القومية لمياه الشرب والصرف الصحي"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button18"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="تحليل سعر لبند مصنعية عمل تحويلات"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
