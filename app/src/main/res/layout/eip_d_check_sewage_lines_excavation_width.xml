<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear3"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:orientation="vertical"
		android:background="@drawable/rectangle_0_tealffe0f2f1_075_blackff000000">
		<LinearLayout
			android:id="@+id/linear2414"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:background="@drawable/rectangle_0_greyffe0e0e0_050_blackff000000">
			<ImageView
				android:id="@+id/close1dw"
				android:layout_width="30dp"
				android:layout_height="30dp"
				android:src="@drawable/clos1"
				android:scaleType="fitCenter"
				android:layout_gravity="left|center_vertical" />
			<LinearLayout
				android:id="@+id/linear2415"
				android:layout_width="wrap_content"
				android:layout_height="15dp"
				android:padding="8dp"
				android:orientation="horizontal"
				android:layout_weight="1" />
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll37"
			android:layout_width="match_parent"
			android:layout_height="7dp"
			android:padding="8dp" />
		<LinearLayout
			android:id="@+id/linear2372"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#FFFFFF"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="right">
			<EditText
				android:id="@+id/edittext557dw"
				android:layout_width="40dp"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:background="#C8E6C9"
				android:gravity="center_horizontal|center_vertical"
				android:text="1"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberDecimal" />
			<TextView
				android:id="@+id/textview557dw"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="right"
				android:text="فحص واستلام العرض قياس رقم :"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_gravity="right|center_vertical" />
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll19"
			android:layout_width="match_parent"
			android:layout_height="7dp"
			android:padding="8dp" />
		<LinearLayout
			android:id="@+id/linear2370"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:background="@drawable/rectangle_0_purplefff3e5f5_050_blackff000000">
			<EditText
				android:id="@+id/edittext_am16dw"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="a.m"
				android:textSize="12sp"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberSigned|numberDecimal"
				android:enabled="false" />
			<TextView
				android:id="@+id/textview2413"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="م"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<EditText
				android:id="@+id/edittext16dw"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#BBDEFB"
				android:gravity="center_horizontal|center_vertical"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberDecimal" />
			<TextView
				android:id="@+id/textview2414"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="="
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview16dw"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="عرض قاع الحفر الفعلي المقاس علي الطبيعة\n( م )"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll18"
			android:layout_width="match_parent"
			android:layout_height="7dp"
			android:padding="8dp" />
		<LinearLayout
			android:id="@+id/linear2378"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="8dp"
			android:gravity="center_horizontal"
			android:orientation="vertical"
			android:background="@drawable/rectangle_0_purplefff3e5f5_050_blackff000000">
			<TextView
				android:id="@+id/textview17dw"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="الفرق\n( عرض الحفر الفعلي المقاس علي الطبيعة\n-\nعرض الحفر التصميمي )\n( م )"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview2425"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="="
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<LinearLayout
				android:id="@+id/linear2373"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview2424"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="م"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<EditText
					android:id="@+id/edittext17dw"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#D7CCC8"
					android:gravity="center_horizontal|center_vertical"
					android:text="00.00"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000"
					android:hint="Edit Text"
					android:textColorHint="#607D8B"
					android:inputType="numberDecimal"
					android:enabled="false" />
			</LinearLayout>
		</LinearLayout>
		<TextView
			android:id="@+id/textview111dw"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:text="عرض الحفر الفعلي يساوي عرض الحفر التصميمي\nالعرض مطابق"
			android:textSize="14sp"
			android:textStyle="bold"
			android:textColor="#000000"
			android:layout_gravity="right" />
		<TextView
			android:id="@+id/textview112dw"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="right|center_vertical"
			android:text="عرض الحفر الفعلي أقل من عرض الحفر التصميمي\nوعليه يرجي زيادة عرض الحفر بقدار الفرق\nملاحظة : ( ve - ) توضح ان انه يجب زيادة عرض الحفر بالمقدار المجاور للعلامة"
			android:textSize="14sp"
			android:textStyle="bold"
			android:textColor="#FF5722"
			android:layout_gravity="right|center_vertical" />
		<TextView
			android:id="@+id/textview113dw"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="right|center_vertical"
			android:text="عرض الحفر الفعلي أكبر من عرض الحفر التصميمي\nوعليه ستتكلف أعمال أحلال وردم بكميات أضافية"
			android:textSize="14sp"
			android:textStyle="bold"
			android:textColor="#4CAF50"
			android:layout_gravity="right|center_vertical" />
	</LinearLayout>
	<HorizontalScrollView
		android:id="@+id/hscroll38"
		android:layout_width="match_parent"
		android:layout_height="10dp"
		android:padding="8dp" />
</LinearLayout>
