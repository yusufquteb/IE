<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<TextView
		android:id="@+id/textview492"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:background="@android:color/transparent"
		android:gravity="center_horizontal|center_vertical"
		android:text="-----‐---------------------------"
		android:textSize="14sp"
		android:textStyle="bold"
		android:textColor="#E91E63" />
	<LinearLayout
		android:id="@+id/dynamic_out_linear1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="center_horizontal|top"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/dynamic_point_number_linear"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#FFFFFF"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="right">
			<TextView
				android:id="@+id/dynamic_point_type"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="بقاع الحفر"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<EditText
				android:id="@+id/dynamic_point_number"
				android:layout_width="40dp"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:background="#C8E6C9"
				android:gravity="center_horizontal|center_vertical"
				android:text=" 1"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B" />
			<TextView
				android:id="@+id/textview1082"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="right"
				android:text="الرفع المساحي للنقطة رقم :"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_gravity="right|center_vertical" />
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll28"
			android:layout_width="match_parent"
			android:layout_height="10dp"
			android:padding="8dp"
			android:layout_gravity="center_horizontal|center_vertical" />
		<LinearLayout
			android:id="@+id/dynamic_out_linear2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#F3E5F5"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview494"
				android:layout_width="wrap_content"
				android:layout_height="35dp"
				android:padding="8dp"
				android:text="م"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<EditText
				android:id="@+id/dynamic_point_reading"
				android:layout_width="75dp"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#BBDEFB"
				android:gravity="center_horizontal|center_vertical"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberDecimal" />
			<TextView
				android:id="@+id/textview495"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="="
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/dynamic_point_reading_name"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="قراءة النقطة علي الميزان \nبالرفع المساحي لقاع الحفر ( م )"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear137"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical">
			<Button
				android:id="@+id/dynamic_point_calculation"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#000000"
				android:text="أحسب\n="
				android:textSize="12sp"
				android:textColor="#4CAF50" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/dynamic_out_linear3"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/dynamic_out_linear5"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:background="#F3E5F5"
				android:gravity="center_horizontal|bottom"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/dynamic_levels_difference_name"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="الفرق ف المنسوب\n( م )\n( &quot;منسوب قاع\nالحفر التصميمي&quot;\n-\n&quot; منسوب النقطة\nالمرفوعة لقاع\nالحفر&quot; )"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<EditText
					android:id="@+id/dynamic_levels_difference"
					android:layout_width="75dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FFC107"
					android:gravity="center_horizontal|center_vertical"
					android:text="00.00"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000"
					android:textColorHint="#607D8B"
					android:inputType="numberDecimal"
					android:enabled="false" />
			</LinearLayout>
			<TextView
				android:id="@+id/textview498"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text=".\n.\n.\n.\n."
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<LinearLayout
				android:id="@+id/dynamic_out_linear4"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:background="#F3E5F5"
				android:gravity="center_horizontal|bottom"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/dynamic_point_level_name"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="\n\n\nمنسوب النقطة\nالمرفوعة لقاع\nالحفر\n\n"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<EditText
					android:id="@+id/dynamic_point_level"
					android:layout_width="75dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FFC107"
					android:gravity="center_horizontal|center_vertical"
					android:text="00.00"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000"
					android:textColorHint="#607D8B"
					android:inputType="numberDecimal"
					android:enabled="false" />
			</LinearLayout>
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll30"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/dynamic_out_linear6"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#F3E5F5"
				android:gravity="right|center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/dynamic_required_action"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text=".............................."
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<TextView
					android:id="@+id/textview502"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text=":"
					android:textSize="14sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<TextView
					android:id="@+id/textview503"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="الأجراء المطلوب"
					android:textSize="14sp"
					android:textStyle="bold"
					android:textColor="#000000" />
			</LinearLayout>
		</HorizontalScrollView>
		<LinearLayout
			android:id="@+id/dynamic_point_remove_linear"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="center_horizontal">
			<Button
				android:id="@+id/dynamic_point_remove"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="إلغاء النقطة\nالحالية"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1" />
			<TextView
				android:id="@+id/textview789"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:textSize="12sp"
				android:textColor="#000000"
				android:layout_weight="1" />
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
