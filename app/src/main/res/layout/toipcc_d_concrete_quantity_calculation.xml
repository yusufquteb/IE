<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/concrete_quantity"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical"
		android:layout_gravity="center_horizontal|center_vertical">
		<TextView
			android:id="@+id/textview519"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:text="-----‐---------------------------"
			android:textSize="14sp"
			android:textStyle="bold"
			android:textColor="#E91E63" />
		<LinearLayout
			android:id="@+id/linear389"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#FFFFFF"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="right">
			<TextView
				android:id="@+id/textview1074"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="("
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/dynamic_element_symble2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<EditText
				android:id="@+id/dynamic_element_serial_numbers"
				android:layout_width="40dp"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:background="@android:color/transparent"
				android:gravity="center_horizontal|center_vertical"
				android:text="1"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberSigned"
				android:enabled="false" />
			<TextView
				android:id="@+id/dynamic_element_symble"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="س"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview1072"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text=")"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<EditText
				android:id="@+id/dynamic_element_serial_number"
				android:layout_width="40dp"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:background="#C8E6C9"
				android:gravity="center_horizontal|center_vertical"
				android:text=" 1"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:textColorHint="#607D8B"
				android:inputType="numberSigned" />
			<TextView
				android:id="@+id/dynamic_element_type"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#FFFFFF"
				android:gravity="right"
				android:text="نموذج سمل رقم"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_gravity="right|center_vertical" />
		</LinearLayout>
		<HorizontalScrollView
			android:id="@+id/hscroll1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/out_dynamic1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_gravity="center_horizontal|center_vertical">
				<LinearLayout
					android:id="@+id/out_dynamic3"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:background="#F3E5F5"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<TextView
						android:id="@+id/dynamic_width_of_element"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="العرض ( م )"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
										<com.google.android.material.textfield.TextInputLayout
					    android:layout_width="75dp"
					    android:layout_height="wrap_content"
					    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
					    app:boxBackgroundColor="#BBDEFB"
					    app:boxStrokeColor="#1565C0"
					    app:hintEnabled="false">
					    <com.google.android.material.textfield.TextInputEditText
						android:id="@+id/dynamic_wid_of_element"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:textColorHint="#607D8B"
						android:inputType="numberDecimal" 
					        android:layout_width="match_parent"
					        android:layout_height="wrap_content" />
					</com.google.android.material.textfield.TextInputLayout>
					<TextView
						android:id="@+id/textview15"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="X"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
					<TextView
						android:id="@+id/dynamic_number_of_element"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="* العدد"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
										<com.google.android.material.textfield.TextInputLayout
					    android:layout_width="75dp"
					    android:layout_height="wrap_content"
					    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
					    app:boxBackgroundColor="#C8E6C9"
					    app:boxStrokeColor="#388E3C"
					    app:hintEnabled="false">
					    <com.google.android.material.textfield.TextInputEditText
						android:id="@+id/dynamic_num_of_element"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:hint="1"
						android:textColorHint="#B0BEC5"
						android:inputType="numberSigned" 
					        android:layout_width="match_parent"
					        android:layout_height="wrap_content" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linear5"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview4"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="X"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/out_dynamic2"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:background="#F3E5F5"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<TextView
						android:id="@+id/dynamic_length_of_element"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="الطول ( م )"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
										<com.google.android.material.textfield.TextInputLayout
					    android:layout_width="75dp"
					    android:layout_height="wrap_content"
					    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
					    app:boxBackgroundColor="#BBDEFB"
					    app:boxStrokeColor="#1565C0"
					    app:hintEnabled="false">
					    <com.google.android.material.textfield.TextInputEditText
						android:id="@+id/dynamic_len_of_element"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:textColorHint="#607D8B"
						android:inputType="numberDecimal" 
					        android:layout_width="match_parent"
					        android:layout_height="wrap_content" />
					</com.google.android.material.textfield.TextInputLayout>
					<TextView
						android:id="@+id/textview14"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="X"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
					<TextView
						android:id="@+id/dynamic_height_of_element"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="الأرتفاع ( م )"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000" />
										<com.google.android.material.textfield.TextInputLayout
					    android:layout_width="75dp"
					    android:layout_height="wrap_content"
					    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
					    app:boxBackgroundColor="#BBDEFB"
					    app:boxStrokeColor="#1565C0"
					    app:hintEnabled="false">
					    <com.google.android.material.textfield.TextInputEditText
						android:id="@+id/dynamic_hei_of_element"
						android:padding="8dp"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="12sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:textColorHint="#B0BEC5"
						android:inputType="numberDecimal" 
					        android:layout_width="match_parent"
					        android:layout_height="wrap_content" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
			</LinearLayout>
		</HorizontalScrollView>
		<LinearLayout
			android:id="@+id/linear240"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<com.google.android.material.button.MaterialButton
							style="@style/Widget.Material3.Button"
				android:id="@+id/dynamic_ele_cal"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:backgroundTint="#000000"
				android:gravity="center_horizontal|center_vertical"
				android:text="أحسب\n="
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#4CAF50"
				android:layout_gravity="center_horizontal|center_vertical"
							app:cornerRadius="16dp" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/out_dynamic4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#F3E5F5"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview708"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="م٣"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
						<com.google.android.material.textfield.TextInputLayout
			    android:layout_width="80dp"
			    android:layout_height="wrap_content"
			    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
			    app:boxBackgroundColor="#D7CCC8"
			    app:boxStrokeColor="#795548"
			    app:hintEnabled="false">
			    <com.google.android.material.textfield.TextInputEditText
				android:id="@+id/dynamic_qu_of_element"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="00.00"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:hint="Edit Text"
				android:textColorHint="#607D8B"
				android:inputType="numberDecimal"
				android:enabled="false" 
			        android:layout_width="match_parent"
			        android:layout_height="wrap_content" />
			</com.google.android.material.textfield.TextInputLayout>
			<TextView
				android:id="@+id/textview13"
				android:layout_width="50dp"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="="
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview12"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:text="الكمية الأجمالية ( م٣ )"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear237"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="right|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="center_horizontal">
			<com.google.android.material.button.MaterialButton
							style="@style/Widget.Material3.Button"
				android:id="@+id/dynamic_element_remove"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="ألغاء السمل\nالحالى"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1"
							app:cornerRadius="16dp" />
			<TextView
				android:id="@+id/textview704"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:textSize="12sp"
				android:textColor="#000000"
				android:layout_weight="2" />
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
