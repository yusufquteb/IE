<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:importantForAccessibility="yes"
	android:contentDescription="Openings input form"
	android:theme="@style/AppTheme.DayNight">
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/cardview1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_margin="8dp"
		style="@style/CardViewStyle.DayNight">
		<LinearLayout
			android:id="@+id/bg"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/linear78"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1">
				<LinearLayout
					android:id="@+id/header_section"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/circle_no"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:background="@drawable/circle_background"
						android:gravity="center_horizontal|center_vertical"
						android:text="1.1"
						android:textSize="14sp"
						android:textStyle="bold"
						android:layout_marginEnd="12dp"
						android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
						android:importantForAccessibility="yes"
						android:contentDescription="Openingnumber"
						android:labelFor="@+id/name" />
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/name_container"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/name"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="Opening Name"
							android:imeOptions="actionNext"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
							android:importantForAccessibility="yes"
							android:contentDescription="Openingnameinputfield" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.button.MaterialButton
						android:id="@+id/remove_button"
						android:layout_width="48dp"
						android:layout_height="48dp"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="12sp"
						android:layout_marginStart="8dp"
						style="@style/Widget.Material3.Button.IconButton.DayNight"
						android:contentDescription="@string/close_icon"
						app:icon="@drawable/icon_disabled_by_default_round"
						app:iconSize="24dp"
						app:iconTint="?attr/colorError" />
				</LinearLayout>
				<com.google.android.material.divider.MaterialDivider
					android:id="@+id/material_divider26"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					style="@style/DividerStyle.DayNight" />
				<LinearLayout
					android:id="@+id/input_section"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview14"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="12dp"
						android:text="📐 نوع وشكل الفتحة"
						android:textSize="16sp"
						android:textStyle="bold"
						android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textInputLayout_areaType"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:layout_weight="1"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
						app:helperTextEnabled="true">
						<AutoCompleteTextView
							android:id="@+id/area_type"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="16dp"
							android:textSize="14sp"
							android:hint="Area Type"
							android:inputType="none"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
							android:importantForAccessibility="yes"
							android:contentDescription="Selectareatype" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textInputLayout_shape"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:layout_weight="1"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
						app:helperTextEnabled="true">
						<AutoCompleteTextView
							android:id="@+id/shape"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="16dp"
							android:textSize="14sp"
							android:hint="Area Shape"
							android:inputType="none"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
							android:importantForAccessibility="yes"
							android:contentDescription="Selectshapetype" />
					</com.google.android.material.textfield.TextInputLayout>
					<TextView
						android:id="@+id/textview15"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:layout_marginBottom="12dp"
						android:text="📏 القياسات"
						android:textSize="16sp"
						android:textStyle="bold"
						android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_no"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
						app:helperTextEnabled="true"
						app:helperText="@string/repetitions_helper"
						app:startIconDrawable="@drawable/icon_repeat"
						app:startIconContentDescription="@string/repetitions_icon">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/no"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="@string/repetitions_hint"
							android:inputType="numberDecimal"
							android:imeOptions="actionNext"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
							android:importantForAccessibility="yes"
							android:contentDescription="Enterquantity" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_length"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:layout_weight="1"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
						app:helperTextEnabled="true"
						app:helperText="@string/length_helper"
						app:suffixText="m"
						app:startIconDrawable="@drawable/icon_straighten"
						app:startIconContentDescription="@string/length_icon">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/len"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="@string/length_hint"
							android:inputType="numberDecimal"
							android:imeOptions="actionNext"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_width"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:layout_weight="1"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
						app:helperTextEnabled="true"
						app:helperText="@string/width_helper"
						app:suffixText="m"
						app:startIconDrawable="@drawable/icon_width"
						app:startIconContentDescription="@string/width_icon">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/width"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="@string/width_hint"
							android:inputType="numberDecimal"
							android:imeOptions="actionDone"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_radius"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
						app:helperTextEnabled="true"
						app:helperText="@string/radius_helper"
						app:suffixText="m"
						app:startIconDrawable="@drawable/icon_radius"
						app:startIconContentDescription="@string/radius_icon">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/radius"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="@string/radius_hint"
							android:inputType="numberDecimal"
							android:imeOptions="actionDone"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_area"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.DayNight"
						app:helperTextEnabled="true"
						app:helperText="@string/area_helper"
						app:suffixText="m²"
						app:startIconDrawable="@drawable/icon_area"
						app:startIconContentDescription="@string/area_icon">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/area"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:hint="@string/area_hint"
							android:inputType="numberDecimal"
							android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/total_card"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						style="@style/CardViewStyle_total.DayNight"
						app:cardCornerRadius="12dp"
						app:cardElevation="2dp">
						<LinearLayout
							android:id="@+id/linear10"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="16dp"
							android:orientation="vertical">
							<TextView
								android:id="@+id/textview16"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginBottom="8dp"
								android:text="📊 المساحة الإجمالية"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />
							<com.google.android.material.textfield.TextInputLayout
								android:id="@+id/TextInputLayout_total"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								style="@style/Widget.Material3.TextInputLayout.FilledBox.Dense.DayNight"
								app:helperTextEnabled="true"
								app:helperText="@string/total_area_helper"
								app:suffixText="m²">
								<com.google.android.material.textfield.TextInputEditText
									android:id="@+id/total_area"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:textSize="16sp"
									android:textStyle="bold"
									android:hint="@string/total_area_hint"
									android:enabled="false"
									android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
							</com.google.android.material.textfield.TextInputLayout>
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</com.google.android.material.card.MaterialCardView>
</LinearLayout>
