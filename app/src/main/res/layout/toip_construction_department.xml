<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/_coordinator"
	android:layout_width="match_parent"
	android:layout_height="match_parent">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/_app_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/AppTheme.AppBarOverlay">
		<androidx.appcompat.widget.Toolbar
			android:id="@+id/_toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="?attr/colorPrimary"
			app:popupTheme="@style/AppTheme.PopupOverlay" />
	</com.google.android.material.appbar.AppBarLayout>
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<com.google.android.gms.ads.AdView
			android:id="@+id/adview1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:adSize="SMART_BANNER"
			app:adUnitId="ca-app-pub-8740221854029861/1241530910" />
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="8dp"
			android:background="#E0F2F1">
			<LinearLayout
				android:id="@+id/linear1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FFFFFF"
					android:gravity="center_horizontal|center_vertical"
					android:text="أقسام المكتب الفني لأعمال الأنشاءات\n---------------------------------------"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#000000"
					android:layout_gravity="center_horizontal" />
				<Button
					android:id="@+id/button1"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند الحفر"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button2"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند الأحلال"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button9"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="مكونات وتكلفة الخرسانة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button10"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حساب وزن ال م.ط من حديد التسليح وحساب سعره"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button3"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند القواعد العادية"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button4"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="حصر كميات وخامات وتكلفة بند القواعد المسلحة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button5"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند السملات"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button6"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند الأعمدة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button7"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند الكمرات"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button8"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وخامات وتكلفة بند الأسقف المصمتة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button14"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر الكميات والخامات وحساب التكلفة للبلاطات الأرضية الخرسانية \nConcrete Slab On Gride"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button13"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وحساب خامات وتكلفة بند الحوائط الخرسانية"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button15"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وحساب خامات وتكلفة بند المباني"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button11"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وحساب خامات وتكلفة بند البياض والمحارة"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
				<Button
					android:id="@+id/button12"
					android:layout_width="200dp"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="حصر كميات وحساب خامات وتكلفة بند الدهانات"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#000000" />
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
