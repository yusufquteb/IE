<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
        
<item
            android:bottom="1dp"
            android:left="1dp"
            android:right="1dp"
            android:top="1dp">
            <shape android:shape="rectangle">
                <stroke
                    android:width="1dp"
                    android:color="#ff5070b0"
                    android:dashGap="4dp"
                    android:dashWidth="4dp" />
                <corners android:radius="5dp"/>
                <solid android:color="#fafafa" />

                <padding
                    android:bottom="0dp"
                    android:left="0dp"
                    android:right="0dp"
                    android:top="0dp" />
            </shape>
        </item>
</layer-list>